# .env.example — copier en .env, ne jamais committer .env

# ─── Base de données ───────────────────────────────────────────────────────────
DATABASE_URL="postgresql://fleetmanager:fleetmanager_dev@localhost:5432/fleetmanager"

# Variables Docker Compose (utilisées dans docker-compose.yml)
POSTGRES_USER="fleetmanager"
POSTGRES_PASSWORD="fleetmanager_dev"
POSTGRES_DB="fleetmanager"

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Générer avec : openssl rand -hex 32
JWT_SECRET="min-64-chars-generer-avec-openssl-rand-hex-32-CHANGEZ-MOI"
JWT_REFRESH_SECRET="min-64-chars-different-de-JWT_SECRET-CHANGEZ-MOI"
JWT_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Application ───────────────────────────────────────────────────────────────
NODE_ENV="development"       # development | production | test
PORT="3000"
TZ="Africa/Algiers"
FRONTEND_URL="http://localhost:5173"   # CORS origin

# ─── Production uniquement ─────────────────────────────────────────────────────
# FRONTEND_URL="https://fleetmanager.example.dz"

# ─── Backup ──────────────────────────────────────────────────────────────────
# Clé de chiffrement AES-256-GCM — générer avec : openssl rand -hex 32
BACKUP_ENCRYPTION_KEY=""
# Répertoire local de stockage des backups chiffrés
BACKUP_LOCAL_DIR="/var/backups/fleetmanager"

# ─── Production — création compte admin initial ───────────────────────────────
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

# ─── EXCLUS DU SCOPE V1 ────────────────────────────────────────────────────────
# Nodemailer / SMTP : reporté V2
# Application mobile : hors scope V1
